# Groq API キー (Whisper 文字起こし用)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion インテグレーショントークン
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 投稿先の親 ID (ページ or データベース)。URL 末尾の 32 桁ハッシュ。
NOTION_PARENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 親種別: auto (既定、API で自動判定) / page / database
# 通常は auto のままで OK
NOTION_PARENT_TYPE=auto

# 任意: 使用する Whisper モデル
# WHISPER_MODEL=whisper-large-v3

# 任意: claude CLI のパス
# CLAUDE_BIN=claude
